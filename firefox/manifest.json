{
  "manifest_version": 2,
  "name": "URLFocus",
  "version": "1.0",
  "description": "Closes social media tabs automatically when they are opened.",
  "icons": {
    "48": "icons/border-48.png"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background-script.js"],
    "persistent": true
  },
  "browser_action": {
    "default_icon": "icons/border-48.png",
    "default_popup": "ui/popup.html"
  }
}
