{
  "manifest_version": 3,
  "name": "URLFocus",
  "version": "1.0",
  "description": "Closes social media tabs automatically when they are opened.",
  "icons": {
    "48": "icons/border-48.png"
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background-script.js"
  }
}
